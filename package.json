{
  "name": "quickbooks-mcp",
  "version": "0.2.0",
  "description": "MCP server for QuickBooks Online API integration",
  "license": "MIT",
  "mcpName": "io.github.laf-rge/quickbooks-mcp",
  "author": "laf-rge",
  "homepage": "https://github.com/laf-rge/quickbooks-mcp",
  "bugs": "https://github.com/laf-rge/quickbooks-mcp/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/laf-rge/quickbooks-mcp.git"
  },
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "quickbooks-mcp": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "build:lambda": "esbuild src/lambda.ts --bundle --platform=node --target=node20 --outfile=dist-lambda/handler.mjs --format=esm --external:@aws-sdk/*",
    "prepare": "npm run build",
    "start": "node dist/index.js",
    "dev": "tsc --watch"
  },
  "keywords": [
    "mcp",
    "quickbooks",
    "api",
    "accounting",
    "model-context-protocol"
  ],
  "dependencies": {
    "@aws-sdk/client-secrets-manager": "^3.700.0",
    "@aws-sdk/client-ssm": "^3.700.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "dotenv": "^17.2.3",
    "intuit-oauth": "^4.2.2",
    "node-quickbooks": "^2.0.47",
    "tmp": "^0.2.3"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/tmp": "^0.2.6",
    "esbuild": "^0.24.2",
    "typescript": "^5.3.0"
  }
}
